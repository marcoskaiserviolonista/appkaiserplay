rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helpers ──────────────────────────────────────────────────────────────

    function isInt(val, min, max) {
      return val is int && val >= min && val <= max;
    }

    function isValidGuitar(id) {
      return id in [
        'violao_basico',
        'violao_bom',
        'violao_luthier',
        'violao_ouro',
        'violao_diamante'
      ];
    }

    // Validates every field that exists in the incoming document.
    // Fields not listed here (stats, chordStats, etc.) are allowed through
    // unchanged — only the economy and progression fields are bounded.
    function isValidPlayer(data) {
      return
        // Numeric economy fields
        (!('xp'         in data) || isInt(data.xp,         0, 10500000))
     && (!('notas'      in data) || isInt(data.notas,      0, 100000000))
     && (!('moedas'     in data) || isInt(data.moedas,     0, 500000))
     && (!('diamantes'  in data) || isInt(data.diamantes,  0, 100000))
     && (!('bestStreak' in data) || isInt(data.bestStreak, 0, 100000))

        // Display name — must be a string of reasonable length
     && (!('displayName' in data) || (
           data.displayName is string
        && data.displayName.size() <= 100
        ))

        // Equipped guitar must be one of the known valid IDs
     && (!('violaoEquipado' in data) || (
           data.violaoEquipado is string
        && isValidGuitar(data.violaoEquipado)
        ))

        // Boolean flags
     && (!('firstCardSeen' in data) || data.firstCardSeen is bool)
     && (!('ratingDone'    in data) || data.ratingDone    is bool);
    }

    // ── Players collection ───────────────────────────────────────────────────

    match /players/{userId} {

      // Users can only read their own document
      allow read: if request.auth != null
               && request.auth.uid == userId;

      // Users can only write their own document, and only with valid data
      allow write: if request.auth != null
                && request.auth.uid == userId
                && isValidPlayer(request.resource.data);
    }

    // ── Block everything else ────────────────────────────────────────────────

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
